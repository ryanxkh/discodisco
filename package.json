{
  "name": "discodisco",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:ext": "dotenv -e .env.local -- tsx scripts/db-extensions.ts",
    "db:push": "dotenv -e .env.local -- drizzle-kit push --force",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "ingest": "dotenv -e .env.local -- tsx scripts/ingest.ts",
    "eval": "dotenv -e .env.local -- bt eval evals/discodisco.eval.ts"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.171",
    "autoevals": "^0.0.132",
    "braintrust": "^3.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "16.2.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.6.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
